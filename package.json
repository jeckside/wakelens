{
  "name": "wakelens",
  "version": "0.3.1",
  "description": "Find out why your Windows PC woke up.",
  "main": "out/main/main.js",
  "author": "jeckside",
  "license": "MIT",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && npm run test && electron-vite build",
    "dist": "npm run build && electron-builder --win nsis --x64",
    "lint": "npm run typecheck",
    "smoke:packaged-localization": "node tests/packaged-localization-smoke.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron-store": "^10.1.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "build": {
    "appId": "dev.jeckside.wakelens",
    "productName": "WakeLens",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
